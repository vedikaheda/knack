{
  "agents": {
    "defaults": {
      "workspace": "/home/node/.openclaw/workspace",
      "compaction": {
        "mode": "safeguard"
      },
      "maxConcurrent": 4
    }
  },
  "tools": {
    "profile": "full"
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "all"
  },
  "hooks": {
    "enabled": true,
    "path": "/hooks",
    "token": "replace-with-the-same-hook-secret-as-your-env",
    "allowRequestSessionKey": true,
    "allowedSessionKeyPrefixes": [
      "agent:",
      "hook:"
    ],
    "internal": {
      "enabled": true
    }
  },
  "channels": {
    "slack": {
      "mode": "socket",
      "enabled": true,
      "userTokenReadOnly": true,
      "groupPolicy": "allowlist",
      "streaming": "partial",
      "nativeStreaming": true
    }
  },
  "plugins": {
    "enabled": true,
    "load": {
      "paths": [
        "/home/node/.openclaw/workspace/knack-v2-plugin"
      ]
    },
    "allow": [
      "knack-v2"
    ],
    "entries": {
      "slack": {
        "enabled": true
      },
      "knack-v2": {
        "enabled": true,
        "config": {
          "FIREFLIES_API_KEY": "replace_me",
          "PROOF_BASE_URL": "http://proof:4000",
          "PROOF_PUBLIC_URL": "http://your-vm-ip:4000",
          "PROOF_OWNER_SECRET_STORE_PATH": ".local/proof/owner-secrets.json",
          "PROOF_TRACKED_DOCS_PATH": "/shared-state/proof/tracked-docs.json",
          "ATTENDEE_BASE_URL": "http://attendee-app:8000",
          "ATTENDEE_API_KEY": "replace_me_after_creating_it_in_attendee_ui",
          "ATTENDEE_DEFAULT_BOT_NAME": "Knack",
          "ATTENDEE_TRACKED_BOTS_PATH": "/shared-state/attendee/tracked-bots.json",
          "ATTENDEE_SARVAM_LANGUAGE_CODE": "en-IN",
          "ATTENDEE_SARVAM_MODEL": "saarika:v2.5",
          "KNACK_AUDIT_LOG_PATH": ".local/audit/events.jsonl",
          "KNACK_REVIEW_WATCH_DAYS": "7",
          "KNACK_AGENT_ID": "knack"
        }
      }
    }
  }
}
